{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "epic",
  "title": "Epic",
  "type": "object",
  "required": ["id", "title", "description", "requirements", "owner", "status", "priority"],
  "additionalProperties": true,
  "properties": {
    "id":          { "type": "string", "minLength": 1 },
    "title":       { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "requirements": { "type": "array", "items": { "type": "string" } },
    "owner":       { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["Backlog", "In Progress", "Completed", "Blocked"]
    },
    "priority": {
      "type": "string",
      "enum": ["High", "Medium", "Low"]
    },
    "notes": { "type": "string" }
  }
}
