{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "framework",
  "title": "Framework",
  "type": "object",
  "required": ["id", "name", "version", "description", "category", "controls", "isActive"],
  "additionalProperties": true,
  "properties": {
    "id":          { "type": "string", "minLength": 1 },
    "name":        { "type": "string", "minLength": 1 },
    "version":     { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["Compliance", "Security", "Privacy", "Quality", "Other"]
    },
    "isActive":      { "type": "boolean" },
    "effectiveDate": { "type": "string" },
    "notes":         { "type": "string" },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "frameworkId", "controlId", "title", "description", "requirements"],
        "additionalProperties": true,
        "properties": {
          "id":           { "type": "string", "minLength": 1 },
          "frameworkId":  { "type": "string", "minLength": 1 },
          "controlId":    { "type": "string", "minLength": 1 },
          "title":        { "type": "string", "minLength": 1 },
          "description":  { "type": "string" },
          "requirements": { "type": "array", "items": { "type": "string" } },
          "category":     { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Low"]
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
