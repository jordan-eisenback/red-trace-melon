# ---------------------------------------------------------------------------
# RTM – Environment Variables Example
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in any values you want to override.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# Never commit .env.local — it is already listed in .gitignore.
# ---------------------------------------------------------------------------

# Log level for the frontend logger (src/app/utils/logger.ts).
# Allowed values: debug | info | warn | error
# Defaults: 'debug' in development, 'warn' in production builds.
# Set to 'debug' to see all context mutations in the browser console.
VITE_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Agent Runner — M365 Agents SDK (server-side, NOT prefixed with VITE_)
# ---------------------------------------------------------------------------
# These are written automatically by `atk provision` (M365 Agents Toolkit).
# You do NOT need to set these manually — provision handles it.
# Docs: open the M365 Agents Toolkit panel → Accounts → sign in → Provision
#
# MicrosoftAppId=          — AAD app client ID (written to .env/.env.local)
# MicrosoftAppTenantId=    — AAD tenant ID      (written to .env/.env.local)
# SECRET_AAD_APP_CLIENT_SECRET= — client secret (written to .env/.env.local.user, gitignored)
#
# Optional: override the Bot Framework Direct Line endpoint used by the agent runner
# AGENT_ENDPOINT=https://directline.botframework.com/v3/directline
