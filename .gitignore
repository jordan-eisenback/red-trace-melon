node_modules/

# Build output
/dist/

# Legacy env folder (superseded by env/)
/.env/

# Script-generated artifacts
/scripts/*.json
/scripts/*.csv
/scripts/*.txt

# Playwright
/playwright-report/
/test-results/
# Script backups (keep current backups in repo if already present, but ignore new ones)
/scripts/backups/

# Vite local
.vite/

# OS files
.DS_Store
Thumbs.db

# Coverage reports (generated by Vitest)
coverage/

# M365 Agents Toolkit — secrets (never commit)
env/.env.local.user
.env/.env.local.user

# Toolkit build output
/build/

# Agent runner — runtime artifacts (memory + output auto-generated per run)
storage/agents/memory/*
storage/agents/output/*
!storage/agents/memory/.gitkeep
!storage/agents/output/.gitkeep
